[gateway]
host = "127.0.0.1"
port = 8765
token = "change-me"
rate_limit_per_minute = 20

[agent]
workspace_dir = "workspace"
model = "gemini-2.0-flash"
max_tokens = 2048
context_window = 32768
max_sessions_per_key = 20
session_max_age_days = 90

[agent.compaction.memory_flush]
enabled = true

[llm]
gemini_api_key = ""
openai_api_key = ""

[channels]
enabled = []

[telegram]
bot_token = ""
allowed_user_ids = []

[memory]
vector_enabled = true
temporal_decay_lambda = 0.02
mmr_lambda = 0.7
multimodal_enabled = true
auto_capture_enabled = true

[automation]
heartbeat_interval_minutes = 15
# Static cron jobs support mode = "direct" for simple reminder delivery or mode = "ai"
# for model-driven briefings and reasoning-heavy automations.
# cron_jobs = [{ schedule = "0 8 * * *", message = "Good morning briefing", mode = "direct" }]
cron_jobs = []

[automation.delivery]
retry_attempts = 3
retry_backoff_seconds = 30
fallback_to_secondary = true

[automation.approvals]
enabled = true
timeout_minutes = 60
default_action = "deny"

[automation.notifications]
inbox_retention_days = 30
default_severity = "info"

[context_engine]
enabled = false
interval_minutes = 180
recent_session_message_limit = 6
session_count_limit = 4
gmail_thread_limit = 5
calendar_event_limit = 6
max_notifications_per_run = 2
min_confidence = 0.82
min_urgency = 0.55
dedupe_days = 7
snapshot_subdir = "context_engine/life_state"
insights_subdir = "context_engine/insights"

[[automation.rules]]
name = "daily-briefing"
trigger = "cron"
prompt_or_skill = "Good morning briefing"
enabled = true
action_policy = "notify_first"
delivery_policy = "primary"
cooldown_seconds = 0
dedupe_window_seconds = 300
quiet_hours_behavior = "queue"
severity = "info"

[tools]
brave_api_key = ""
browser_headless = true
browser_profiles_subdir = "browser_sessions"
browser_screenshots_subdir = "browser"
browser_downloads_subdir = "inbox/browser_downloads"
browser_log_retention = 200
browser_screenshot_stream_interval_seconds = 3

[browser_workflows]
enabled = true
classifier_confidence_threshold = 0.82
max_results_to_rank = 8
allow_auto_play = true
ask_before_high_impact = true
llm_classifier_enabled = true

[browser_execution]
default_mode = "headless"
headed_login_required = true
headed_on_blockers = true
headed_on_high_impact = true
revert_to_headless_after_manual_step = true
keep_headed_browser_alive_seconds = 60

[oauth.google]
client_id = ""
client_secret = ""

[oauth.github]
client_id = ""
client_secret = ""

[sandbox]
enabled = false
image = "python:3.12-slim"
cpu_limit = 0.5
memory_limit_mb = 512

[system_access]
enabled = false
home_root = "~"
shell = "powershell"
approval_timeout_seconds = 300
ask_once_session_cache = true
default_outside_policy = "deny"
protected_roots = [
  "C:/Windows",
  "C:/Program Files",
  "C:/Program Files (x86)",
  "C:/ProgramData",
  "~/AppData",
  "C:/$Recycle.Bin",
  "C:/System Volume Information",
  "R:/$Recycle.Bin",
  "R:/System Volume Information",
]
audit_log_path = "~/.assistant/logs/system_actions.jsonl"
backup_root = "~/.assistant/backups/system_access"

[[system_access.path_rules]]
path = "~/Desktop"
read = "auto_allow"
write = "ask_once"
overwrite = "always_ask"
delete = "always_ask"
execute = "ask_once"

[[system_access.path_rules]]
path = "~/Documents"
read = "auto_allow"
write = "ask_once"
overwrite = "always_ask"
delete = "always_ask"
execute = "ask_once"

[[system_access.path_rules]]
path = "~/Downloads"
read = "auto_allow"
write = "ask_once"
overwrite = "always_ask"
delete = "always_ask"
execute = "ask_once"

[[system_access.path_rules]]
path = "~/Pictures"
read = "auto_allow"
write = "ask_once"
overwrite = "always_ask"
delete = "always_ask"
execute = "ask_once"

[[system_access.path_rules]]
path = "~/Music"
read = "auto_allow"
write = "ask_once"
overwrite = "always_ask"
delete = "always_ask"
execute = "ask_once"

[[system_access.path_rules]]
path = "~/Videos"
read = "auto_allow"
write = "ask_once"
overwrite = "always_ask"
delete = "always_ask"
execute = "ask_once"

[[system_access.path_rules]]
path = "R:/"
read = "auto_allow"
write = "ask_once"
overwrite = "always_ask"
delete = "always_ask"
execute = "ask_once"

[users]
default_user_id = "default"
primary_channel = "webchat"
fallback_channels = ["telegram"]
quiet_hours_start = ""
quiet_hours_end = ""
notification_level = "normal"
automation_enabled = true
auto_link_single_user = true
